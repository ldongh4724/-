<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>나의 Vercel 매매일지</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>📈 매매일지 Pro</h1>

        <section class="summary-section">
            <h3>📊 기간별 수익률 현황</h3>
            <table>
                <thead>
                    <tr>
                        <th>오늘</th>
                        <th>이번 주</th>
                        <th>이번 달</th>
                        <th>올해</th>
                    </tr>
                </thead>
                <tbody id="summaryTable">
                    <tr>
                        <td id="dayProfit">-</td>
                        <td id="weekProfit">-</td>
                        <td id="monthProfit">-</td>
                        <td id="yearProfit">-</td>
                    </tr>
                </tbody>
            </table>
        </section>

        <section class="input-section">
            <input type="text" id="stockName" placeholder="종목명">
            <input type="number" id="buyPrice" placeholder="매수가">
            <input type="number" id="sellPrice" placeholder="매도가">
            <textarea id="memo" placeholder="매매 복기 및 메모"></textarea>
            <div class="file-input">
                <label for="imageInput">🖼️ 차트 사진 첨부</label>
                <input type="file" id="imageInput" accept="image/*">
            </div>
            <button onclick="addLog()">매매 기록 저장</button>
        </section>

        <section class="log-list" id="logList"></section>
    </div>
    <script src="script.js"></script>
</body>
</html>
