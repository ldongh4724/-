let logs = JSON.parse(localStorage.getItem('tradeLogs') || '[]');

window.onload = () => {
    updateSummary();
    displayLogs();
};

function addLog() {
    const name = document.getElementById('stockName').value;
    const buy = parseFloat(document.getElementById('buyPrice').value);
    const sell = parseFloat(document.getElementById('sellPrice').value);
    const memo = document.getElementById('memo').value;
    const imageInput = document.getElementById('imageInput');

    if (!name || isNaN(buy) || isNaN(sell)) return alert("종목과 가격을 확인하세요!");

    const reader = new FileReader();
    if (imageInput.files[0]) {
        reader.readAsDataURL(imageInput.files[0]);
        reader.onload = () => saveAndRefresh(name, buy, sell, memo, reader.result);
    } else {
        saveAndRefresh(name, buy, sell, memo, null);
    }
}

function saveAndRefresh(name, buy, sell, memo, imageData) {
    const profitRate = ((sell - buy) / buy * 100).toFixed(2);
    const newLog = {
        id: Date.now(),
        date: new Date().toISOString(),
        name, buy, sell, memo, profitRate,
        image: imageData
    };

    logs.push(newLog);
    localStorage.setItem('tradeLogs', JSON.stringify(logs));
    
    // 입력창 초기화
    document.querySelectorAll('input, textarea').forEach(el => el.value = '');
    updateSummary();
    displayLogs();
}

function updateSummary() {
    const now = new Date();
    const oneDay = 24 * 60 * 60 * 1000;
    
    const calc = (filterFn) => {
        const filtered = logs.filter(filterFn);
        if (filtered.length === 0) return "0%";
        const sum = filtered.reduce((acc, cur) => acc + parseFloat(cur.profitRate), 0);
        return (sum / filtered.length).toFixed(2) + "%";
    };

    document.getElementById('dayProfit').innerText = calc(l => (now - new Date(l.date)) < oneDay);
    document.getElementById('weekProfit').innerText = calc(l => (now - new Date(l.date)) < oneDay * 7);
    document.getElementById('monthProfit').innerText = calc(l => (now - new Date(l.date)) < oneDay * 30);
    document.getElementById('yearProfit').innerText = calc(l => (now - new Date(l.date)) < oneDay * 365);
}

function displayLogs() {
    const list = document.getElementById('logList');
    list.innerHTML = logs.slice().reverse().map(log => `
        <div class="log-item">
            <strong>${new Date(log.date).toLocaleDateString()} | ${log.name}</strong>
            <span>수익률: <span class="${log.profitRate >= 0 ? 'plus' : 'minus'}">${log.profitRate}%</span></span>
            <p style="color: #666; font-size: 0.9em;">${log.memo}</p>
            ${log.image ? `<img src="${log.image}" class="log-img">` : ''}
        </div>
    `).join('');
}
